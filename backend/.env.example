# Local dev only — Render/Railway/etc. inject PORT themselves; do not set it there.
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spark-tms?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
# CORS allow-origin — must be the deployed frontend's exact URL in production
# (e.g. https://spark-tms.netlify.app), or the browser will block API requests.
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Email (SMTP) — leave blank to disable email sending (logs to console instead)
# Works with Gmail (use App Password), Outlook, or any SMTP server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=SPARK TMS <noreply@spark.gov.ph>
